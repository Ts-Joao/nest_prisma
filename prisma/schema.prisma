generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Task {
  id          Int       @id @default(autoincrement())
  name       String
  description String
  completed   Boolean   @default(false)
  creaeteAt   DateTime? @default(now()) @map("create_at")

  @@map("tasks")
}
